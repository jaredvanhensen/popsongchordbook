{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/song/**",
        "destination": "/song.html"
      },
      {
        "source": "/artist/**",
        "destination": "/artist.html"
      }
    ]
  }
}
