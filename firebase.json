{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/song/**",
        "destination": "/song.html"
      },
      {
        "source": "/artist/**",
        "destination": "/artist.html"
      }
    ]
  }
}
