{
  "rules": {
    "users": {
      ".read": "auth != null && (auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists())",
      "$userId": {
        ".read": "$userId === auth.uid || root.child('teacherStudents').child(auth.uid).child($userId).val() === true || root.child('teacherStudents').child($userId).child(auth.uid).val() === true",
        ".write": "$userId === auth.uid || auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists()",
        "songs": {
          ".read": "$userId === auth.uid || root.child('teacherStudents').child(auth.uid).child($userId).val() === true",
          ".write": "$userId === auth.uid"
        },
        "setlists": {
          ".read": "$userId === auth.uid || root.child('teacherStudents').child(auth.uid).child($userId).val() === true",
          ".write": "$userId === auth.uid"
        },
        "pendingSongs": {
          ".read": "$userId === auth.uid || root.child('teacherStudents').child(auth.uid).child($userId).val() === true",
          ".write": "auth != null"
        },
        "email": {
          ".read": "$userId === auth.uid || root.child('teacherStudents').child(auth.uid).child($userId).val() === true || root.child('teacherStudents').child($userId).child(auth.uid).val() === true",
          ".write": "$userId === auth.uid"
        }
      }
    },
    "publicSongs": {
      ".read": "auth != null",
      "$songId": {
        ".write": "auth != null && (data.val() == null || data.child('submittedBy').val() === auth.uid || auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists())"
      }
    },
    "emailToUserId": {
      "$email": {
        ".read": "auth != null",
        ".write": "auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists() || (auth != null && newData.val() === auth.uid)"
      }
    },
    "leaderboards": {
      ".read": true,
      ".write": "auth != null",
      "$modeKey": {
        "$userId": {
          ".write": "$userId === auth.uid"
        }
      }
    },
    "songRequests": {
      ".read": "auth != null && (auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists())",
      ".write": "auth != null"
    },
    "fixRequests": {
      ".read": "auth != null && (auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists())",
      ".write": "auth != null"
    },
    "settings": {
      ".read": true,
      ".write": "auth != null && auth.token.email === 'jared@vanhensen.nl'"
    },
    "teacherCodes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && newData.val() === auth.uid"
      }
    },
    "teacherStudents": {
      "$teacherUid": {
        ".read": "$teacherUid === auth.uid",
        "$studentUid": {
          ".write": "$studentUid === auth.uid"
        }
      }
    },
    "studentProgress": {
      "$teacherUid": {
        ".read": "$teacherUid === auth.uid",
        ".write": "$teacherUid === auth.uid",
        "$studentUid": {
          ".read": "$studentUid === auth.uid || $teacherUid === auth.uid",
          ".write": "$studentUid === auth.uid || $teacherUid === auth.uid"
        }
      }
    },
    "studentMessages": {
      "$teacherUid": {
        ".read": "$teacherUid === auth.uid",
        "$studentUid": {
          ".read": "$studentUid === auth.uid || $teacherUid === auth.uid",
          ".write": "$studentUid === auth.uid || $teacherUid === auth.uid"
        }
      }
    },
    "facebookPromoSuite": {
      ".read": "auth != null && (auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.email === 'jared@vanhensen.nl' || root.child('settings').child('admins').child(auth.uid).exists())"
    },
    "bands": {
      "$bandId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "bandCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "bandMembers": {
      "$bandId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "bandSync": {
      "$bandId": {
        ".read": "auth != null && root.child('bandMembers').child($bandId).child(auth.uid).exists()",
        ".write": "auth != null && root.child('bandMembers').child($bandId).child(auth.uid).exists()"
      }
    }
  }
}
